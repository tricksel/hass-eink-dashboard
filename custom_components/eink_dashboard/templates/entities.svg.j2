{%- from "_macros.svg.j2" import widget_title, card_container,
    card_row -%}
<svg xmlns="http://www.w3.org/2000/svg"
     width="{{ w }}" height="{{ h }}">
{%- if has_rows -%}
{{ widget_title(title, title_font_sz, fill=hex_gray) }}
{%- call card_container(
    x=0, y=content_y, w=w, h=content_h,
    card_style=card_style,
    radius=m_radius, border=m_border,
    bar_width=bar_width,
    border_color=hex_black, bar_color=hex_gray) -%}
{%- for row in rows -%}
{%- if row.row_type == "entity" -%}
{#- The name renders in the secondary (smaller, gray) style
    and the value in the primary (larger, black) style, so
    the metrics are cross-wired here: m_font_secondary feeds
    font_primary (name) and m_font_primary feeds font_value
    (value) -- the value gets visual priority. -#}
{{ card_row(
    x=x_off, y=row.y,
    w=w - x_off - r_inset, row_h=row_h,
    padding=m_padding, icon_dia=m_icon_dia,
    inner_gap=m_inner_gap, border=icon_stroke_w,
    font_primary=m_font_secondary,
    font_secondary=m_font_secondary,
    font_value=m_font_primary,
    icon_inner=m_icon_inner,
    letter_font_sz=m_font_letter,
    primary=row.primary,
    secondary="",
    value=row.value,
    icon_svg=row.icon_svg,
    icon_fill=row.icon_fill,
    icon_outline=row.icon_outline,
    icon_no_circle=row.icon_no_circle,
    primary_fill=hex_gray,
    secondary_fill=hex_gray,
    value_fill=hex_black,
    value_bold=value_bold,
    letter=row.letter,
    lpad=lpad, rpad=rpad,
    hex_black=hex_black, hex_white=hex_white) }}
{%- if row.draw_divider -%}
<line
  x1="{{ x_off + lpad }}"
  y1="{{ row.y + row_h }}"
  x2="{{ w - r_inset - rpad }}"
  y2="{{ row.y + row_h }}"
  stroke="{{ hex_light_gray }}"
  stroke-width="{{ divider_stroke_w }}"/>
{%- endif -%}
{%- elif row.row_type == "divider" -%}
<line
  x1="{{ x_off + lpad }}"
  y1="{{ row.line_y }}"
  x2="{{ w - r_inset - rpad }}"
  y2="{{ row.line_y }}"
  stroke="{{ hex_light_gray }}"
  stroke-width="{{ divider_stroke_w }}"/>
{%- elif row.row_type == "section" -%}
<text
  x="{{ x_off + lpad }}"
  y="{{ row.text_y }}"
  font-family="Roboto"
  font-size="{{ row.font_sz }}"
  dominant-baseline="central"
  fill="{{ hex_gray }}">{{ row.label }}</text>
{%- endif -%}
{%- endfor -%}
{%- endcall -%}
{%- endif -%}
</svg>
