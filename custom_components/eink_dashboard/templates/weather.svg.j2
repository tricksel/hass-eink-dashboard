{%- from "_macros.svg.j2" import card_container -%}
<svg xmlns="http://www.w3.org/2000/svg"
     width="{{ w }}" height="{{ h }}">
<rect width="{{ w }}" height="{{ h }}" fill="white"/>
{%- if has_state -%}
{# xo and ri are unused — absolute positions are pre-computed by the context builder #}
{%- call(xo, ri) card_container(
    x=0, y=0, w=card_w, h=total_h,
    card_style=card_style,
    radius=m_radius, border=m_border,
    padding=m_padding, left_bar=m_left_bar,
    grayscale_levels=grayscale_levels) -%}
{# Row 1: condition icon, temperature, today hi/lo/precip. #}
{%- if icon_svg -%}
<g transform="translate({{ icon_x }}, {{ icon_y }})">{{ icon_svg }}</g>
{%- endif -%}
<text
  x="{{ temp_x }}" y="{{ temp_y }}"
  font-family="Roboto"
  font-size="{{ font_xl }}"
  dominant-baseline="central"
  fill="#000000">{{ temp_text }}</text>
{%- if hi_text -%}
<text
  x="{{ hilo_right }}" y="{{ hi_y }}"
  font-family="Roboto"
  font-size="{{ font_sm }}"
  text-anchor="end"
  dominant-baseline="hanging"
  fill="#000000">{{ hi_text }}</text>
{%- endif -%}
{%- if lo_text -%}
<text
  x="{{ hilo_right }}" y="{{ lo_y }}"
  font-family="Roboto"
  font-size="{{ font_sm }}"
  text-anchor="end"
  dominant-baseline="hanging"
  fill="#787878">{{ lo_text }}</text>
{%- endif -%}
{%- if precip_text -%}
<text
  x="{{ hilo_right }}" y="{{ precip_y }}"
  font-family="Roboto"
  font-size="{{ font_xs }}"
  text-anchor="end"
  dominant-baseline="hanging"
  fill="#787878">{{ precip_text }}</text>
{%- endif -%}
{# Detail row: icon + text pairs for each weather attribute. #}
{%- for d in detail_items -%}
{%- if d.icon_svg -%}
<g transform="translate({{ d.icon_x }}, {{ d.icon_y }})">{{ d.icon_svg }}</g>
{%- endif -%}
<text
  x="{{ d.text_x }}" y="{{ d.text_y }}"
  font-family="Roboto"
  font-size="{{ font_sm }}"
  dominant-baseline="central"
  fill="#000000">{{ d.text }}</text>
{%- endfor -%}
{# Separator and forecast grid. #}
{%- if has_forecast -%}
<line
  x1="{{ sep_x1 }}" y1="{{ sep_y }}"
  x2="{{ sep_x2 }}" y2="{{ sep_y }}"
  stroke="#787878"
  stroke-width="{{ sep_thickness }}"/>
{%- for day in forecast_entries -%}
<text
  x="{{ day.cx }}" y="{{ day.label_y }}"
  font-family="Roboto"
  font-size="{{ font_sm }}"
  text-anchor="middle"
  dominant-baseline="hanging"
  fill="#787878">{{ day.label }}</text>
{%- if day.icon_svg -%}
<g transform="translate({{ day.icon_x }}, {{ day.icon_y }})">{{ day.icon_svg }}</g>
{%- endif -%}
{%- if day.hi -%}
<text
  x="{{ day.cx }}" y="{{ day.hi_y }}"
  font-family="Roboto"
  font-size="{{ font_sm }}"
  text-anchor="middle"
  dominant-baseline="hanging"
  fill="#000000">{{ day.hi }}</text>
{%- endif -%}
{%- if day.lo -%}
<text
  x="{{ day.cx }}" y="{{ day.lo_y }}"
  font-family="Roboto"
  font-size="{{ font_sm }}"
  text-anchor="middle"
  dominant-baseline="hanging"
  fill="#787878">{{ day.lo }}</text>
{%- endif -%}
{%- if day.precip -%}
<text
  x="{{ day.cx }}" y="{{ day.precip_y }}"
  font-family="Roboto"
  font-size="{{ font_xs }}"
  text-anchor="middle"
  dominant-baseline="hanging"
  fill="#787878">{{ day.precip }}</text>
{%- endif -%}
{%- endfor -%}
{%- endif -%}
{%- endcall -%}
{%- endif -%}
</svg>
