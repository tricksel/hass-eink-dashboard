{#
  Shared SVG macros for e-ink dashboard widget templates.

  Widget templates import these macros and compose them to build their
  layout.  The Python context builder pre-computes all positions and
  sizes; macros receive final coordinates and emit SVG elements only --
  no layout math happens inside a macro.

  Usage:
    {%- from "_macros.svg.j2" import widget_title, card_container,
        card_row, chip -%}
#}

{#
  widget_title -- draw the optional gray title label above a card.

  Emits a single <text> element at (x, 0) with dominant-baseline="hanging"
  so the title sits flush at the top of the widget viewport.  When title
  is empty the macro emits nothing.

  Parameters:
    title     -- title string; empty = no output
    font_sz   -- font size in pixels
    x         -- horizontal position (default 0)
#}
{%- macro widget_title(title, font_sz, fill, x=0) -%}
{%- if title -%}
<text
  x="{{ x }}" y="0"
  font-family="Roboto"
  font-size="{{ font_sz }}"
  dominant-baseline="hanging"
  fill="{{ fill }}">{{ title }}</text>
{%- endif -%}
{%- endmacro -%}


{#
  card_container -- draw card decoration and wrap inner content.

  Purely decorative: emits the border rect or left-bar rect for the
  chosen card_style, then renders the caller block.  All content
  positioning is pre-computed in Python via _card_insets(); this
  macro only draws the chrome.

    {% call card_container(
        x=0, y=0, w=400, h=200,
        card_style="border",
        radius=m_radius, border=m_border,
        bar_width=bar_width) %}
      ... widget content at pre-computed positions ...
    {% endcall %}

  Parameters:
    x, y         -- top-left of the card area
    w, h         -- card dimensions
    border_color -- hex fill for "border" style stroke
    bar_color    -- hex fill for "left_bar" style rect
    card_style   -- "border", "left_bar", or "none"; unrecognised
                    values are treated as "none" (no decoration)
    radius       -- corner radius for "border" style
    border       -- stroke width for "border" style
    bar_width    -- pre-computed bar width for "left_bar" style
                    (Python is the single source of truth)
#}
{%- macro card_container(
    x, y, w, h,
    border_color, bar_color,
    card_style="none",
    radius=0, border=2,
    bar_width=0
) -%}
{%- if card_style == "border" -%}
{# SVG strokes are centred on the path (half inside, half outside).
   Inset the rect by border//2 so the stroke grows fully inward,
   matching PIL's rounded_rectangle which strokes entirely inside
   the declared bounding box. #}
<rect
  x="{{ x + border // 2 }}" y="{{ y + border // 2 }}"
  width="{{ w - border }}" height="{{ h - border }}"
  rx="{{ radius }}" ry="{{ radius }}"
  fill="none"
  stroke="{{ border_color }}"
  stroke-width="{{ border }}"/>
{{ caller() }}
{%- elif card_style == "left_bar" -%}
<rect
  x="{{ x }}" y="{{ y }}"
  width="{{ bar_width }}" height="{{ h }}"
  fill="{{ bar_color }}"/>
{{ caller() }}
{%- else -%}
{{ caller() }}
{%- endif -%}
{%- endmacro -%}


{#
  card_row -- draw one entity row with icon circle, text, and value.

  Lays out a single row: a circular icon area on the left, a primary
  label with an optional secondary line in the centre, and an optional
  right-aligned value string.  Dimensions come from the WidgetMetrics
  computed by the Python context builder (padding, icon_dia, etc.).

  Icon content priority: icon_svg > letter > empty circle.
  icon_svg is a string produced by the mdi_svg or weather_svg filter;
  it is rendered at 60 % of icon_dia so the circle shows a visible ring.
  When icon_svg is empty and letter is set, the letter is drawn centred
  in the circle instead.

  Parameters:
    x, y      -- top-left of the row content area (after container
                 x_off has been applied)
    w, row_h  -- row dimensions
    padding   -- horizontal inset applied to icon position and value
    icon_dia  -- circle diameter
    inner_gap -- gap between circle right edge and text
    border    -- stroke width for outlined icon circle
    font_primary   -- Roboto Medium font size for the main label
    font_secondary -- font size for secondary text and value
    icon_fill      -- hex fill color for solid icon circle
    primary_fill   -- hex color for primary text
    secondary_fill -- hex color for secondary text
    value_fill     -- hex color for value text
    hex_black -- hex black for outlined circle stroke and icon color
    hex_white -- hex white for outlined circle fill
    primary   -- main label text
    secondary -- sub-label text (empty = single-line row)
    value     -- right-aligned value string (empty = omitted)
    icon_svg  -- pre-built icon SVG string (empty = letter fallback)
    icon_outline -- when true, circle is white with black stroke
    letter    -- fallback letter drawn in circle when icon_svg is empty
    lpad      -- left padding override; -1 (default) uses padding
    rpad      -- right padding override; -1 (default) uses padding
#}
{%- macro card_row(
    x, y, w, row_h,
    padding, icon_dia, inner_gap, border,
    font_primary, font_secondary,
    icon_fill, primary_fill, secondary_fill, value_fill,
    hex_black, hex_white,
    primary="", secondary="", value="",
    icon_svg="",
    icon_outline=false,
    letter="",
    lpad=-1, rpad=-1
) -%}
{%- set lpad = lpad if lpad >= 0 else padding -%}
{%- set rpad = rpad if rpad >= 0 else padding -%}
{%- set icon_cx = x + lpad + icon_dia // 2 -%}
{%- set icon_cy = y + row_h // 2 -%}
{%- set icon_r = icon_dia // 2 -%}
{# Icon circle -- outline or solid fill #}
{%- if icon_outline -%}
<circle
  cx="{{ icon_cx }}" cy="{{ icon_cy }}" r="{{ icon_r }}"
  fill="{{ hex_white }}"
  stroke="{{ hex_black }}"
  stroke-width="{{ border }}"/>
{%- else -%}
<circle
  cx="{{ icon_cx }}" cy="{{ icon_cy }}" r="{{ icon_r }}"
  fill="{{ icon_fill }}"/>
{%- endif -%}
{# Icon content: inlined SVG or letter fallback #}
{%- if icon_svg -%}
{%- set icon_sz = icon_dia * 60 // 100 -%}
{%- set ix = icon_cx - icon_sz // 2 -%}
{%- set iy = icon_cy - icon_sz // 2 -%}
{# Outlined circles are white so the icon must be black to stay
   legible; solid-fill circles are dark so the icon is white. #}
{%- set ic = hex_black if icon_outline else hex_white -%}
<g transform="translate({{ ix }}, {{ iy }})"
  style="color: {{ ic }}">{{ icon_svg }}</g>
{%- elif letter -%}
{%- set lc = hex_black if icon_outline else hex_white -%}
<text
  x="{{ icon_cx }}" y="{{ icon_cy }}"
  font-family="Roboto"
  font-size="{{ icon_dia * 5 // 10 }}"
  text-anchor="middle"
  dominant-baseline="central"
  fill="{{ lc }}">{{ letter }}</text>
{%- endif -%}
{%- set tx = x + lpad + icon_dia + inner_gap -%}
{# Text block -- vertically center primary + optional secondary #}
{%- if secondary -%}
{# (row_h * 4 + 50) // 100 is integer rounding of row_h * 0.04,
   matching PIL's round(row_h * 0.04). #}
{%- set lg = [2, (row_h * 4 + 50) // 100]|max -%}
{%- set bh = font_primary + lg + font_secondary -%}
{%- set bt = y + (row_h - bh) // 2 -%}
{%- set py = bt + font_primary // 2 -%}
{%- set sy = bt + font_primary + lg + font_secondary // 2 -%}
<text
  x="{{ tx }}" y="{{ py }}"
  font-family="Roboto" font-weight="500"
  font-size="{{ font_primary }}"
  dominant-baseline="central"
  fill="{{ primary_fill }}">{{ primary }}</text>
<text
  x="{{ tx }}" y="{{ sy }}"
  font-family="Roboto"
  font-size="{{ font_secondary }}"
  dominant-baseline="central"
  fill="{{ secondary_fill }}">{{ secondary }}</text>
{%- else -%}
{# dominant-baseline="central" centres on the em-square midpoint.
   PIL centres on visible ink height by subtracting the ascender gap
   (bb[1]).  The difference is a few pixels and acceptable for e-ink. #}
<text
  x="{{ tx }}" y="{{ y + row_h // 2 }}"
  font-family="Roboto" font-weight="500"
  font-size="{{ font_primary }}"
  dominant-baseline="central"
  fill="{{ primary_fill }}">{{ primary }}</text>
{%- endif -%}
{# Right-aligned value text #}
{%- if value -%}
<text
  x="{{ x + w - rpad }}" y="{{ y + row_h // 2 }}"
  font-family="Roboto"
  font-size="{{ font_secondary }}"
  text-anchor="end"
  dominant-baseline="central"
  fill="{{ value_fill }}">{{ value }}</text>
{%- endif -%}
{%- endmacro -%}


{#
  chip -- draw an icon-and-text label with state circle.

  When icon_svg is present, a circle is drawn around the icon.
  active controls the circle style (mirrors card_row):
    active=true  → filled gray circle, white icon
    active=false → outlined circle (white fill, black stroke),
                   black icon

  All internal proportional sizing is driven by h:
    pad      = h * 0.18  (horizontal padding)
    icon_dia = h * 0.64  (circle diameter)
    icon_svg   at 60 % of icon_dia  (_CHIP_ICON_INNER_RATIO in
               render.py; rendered by the Python context builder)
    gap      = h * 0.14  (circle-to-text gap)
    font     = h * 0.46  (font size)

  w must be pre-computed by the Python context builder because it
  depends on the rendered text width (which requires font metrics
  unavailable in Jinja2).

  Parameters:
    x, y      -- top-left of the label
    w         -- pre-computed label width
    h         -- label height (controls all internal sizing)
    text      -- label text
    border    -- stroke width for outlined circle
    icon_fill -- hex fill color for the active (filled) circle
    text_fill -- hex color for label text
    hex_black -- hex black for outlined circle stroke and icon color
    hex_white -- hex white for outlined circle fill
    icon_svg  -- pre-built icon SVG string (empty = text-only)
    active    -- when true, circle is filled; when false, outlined
#}
{%- macro chip(
    x, y, w, h, text, border,
    icon_fill, text_fill, hex_black, hex_white,
    icon_svg="", active=false
) -%}
{%- set pad = h * 18 // 100 -%}
{%- set icon_dia = h * 64 // 100 -%}
{%- set icon_gap = h * 14 // 100 -%}
{%- set font_sz = [10, h * 46 // 100]|max -%}
{%- if icon_svg -%}
{%- set icon_cx = x + pad + icon_dia // 2 -%}
{%- set icon_cy = y + h // 2 -%}
{%- set icon_r = icon_dia // 2 -%}
{# State circle -- filled when active, outlined when inactive #}
{%- if active -%}
<circle
  cx="{{ icon_cx }}" cy="{{ icon_cy }}" r="{{ icon_r }}"
  fill="{{ icon_fill }}"/>
{%- else -%}
<circle
  cx="{{ icon_cx }}" cy="{{ icon_cy }}" r="{{ icon_r }}"
  fill="{{ hex_white }}"
  stroke="{{ hex_black }}"
  stroke-width="{{ border }}"/>
{%- endif -%}
{%- set icon_sz = icon_dia * 60 // 100 -%}
{%- set ix = icon_cx - icon_sz // 2 -%}
{%- set iy = icon_cy - icon_sz // 2 -%}
{%- set ic = hex_white if active else hex_black -%}
<g transform="translate({{ ix }}, {{ iy }})"
  style="color: {{ ic }}">{{ icon_svg }}</g>
{%- endif -%}
{%- set tx = x + pad + (icon_dia + icon_gap if icon_svg else 0) -%}
<text
  x="{{ tx }}" y="{{ y + h // 2 }}"
  font-family="Roboto"
  font-size="{{ font_sz }}"
  dominant-baseline="central"
  fill="{{ text_fill }}">{{ text }}</text>
{%- endmacro -%}
